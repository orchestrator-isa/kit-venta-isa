# HubSpot (opcional)
HUBSPOT_API_KEY=TU_API_KEY

# OpenAI (opcional, para IA avanzada)
OPENAI_API_KEY=sk-...

# JWT Secret (para autenticación admin)
JWT_SECRET=tu_secreto_muy_largo_y_aleatorio
